{
  "_README": "Copy this file to .mcp.json and replace the __REPLACE_WITH_*__ placeholders with real bearers. Source values from kv_store.creds.* (see docs/secrets/INDEX.md). .mcp.json is gitignored to keep bearers out of the repo. Rotate via the cred-rotation protocol before committing changes here.",
  "mcpServers": {
    "ecodia": {
      "type": "http",
      "url": "https://api.admin.ecodia.au/api/mcp/ecodia",
      "headers": {
        "Authorization": "Bearer __REPLACE_WITH_ECODIA_BEARER__"
      }
    },
    "coord": {
      "type": "http",
      "url": "http://localhost:7456/api/mcp/coord",
      "headers": {
        "Authorization": "Bearer __REPLACE_WITH_COORD_BEARER__"
      },
      "_comment": "Local coord bus on Corazon (laptop-agent). 8 coord.* tools for inter-CC-tab coordination. Workers identify via X-Tab-Id + X-Tab-Credential headers, or via tab_id/tab_credential in tool params. Shipped 2026-05-18."
    },
    "ecodia-full": {
      "type": "http",
      "url": "https://api.admin.ecodia.au/api/mcp/ecodia-full",
      "headers": {
        "Authorization": "Bearer __REPLACE_WITH_ECODIA_FULL_BEARER__"
      },
      "_comment_lane_e": "Wider bearer (68 scopes). Re-exposes all 22 cowork tools + proxies 10 stdio MCP servers (135 child tools) for a single-bearer 157-tool surface. shell_exec gated. Shipped 2026-05-15."
    },
    "factory": {
      "type": "stdio",
      "command": "/home/tate/ecodiaos/mcp-servers/factory/start.sh",
      "args": [],
      "_comment_local": "VPS-only path; ignored on Corazon. Will be subsumed by /api/mcp/ecodia-full HTTP proxy in a follow-up sprint."
    },
    "google-workspace": {
      "type": "stdio",
      "command": "/home/tate/ecodiaos/mcp-servers/google-workspace/start.sh",
      "args": []
    },
