mat('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Space Grotesk';\n  font-style: normal;\n  font-weight: 600;\n  font-display: swap;\n  src: url(\"fc8bbabe-2914-4b64-9205-aae6e199c914\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n/* vietnamese */\n@font-face {\n  font-family: 'Space Grotesk';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"854c7fdc-9f3e-4561-87f6-e35776379d38\") format('woff2');\n  unicode-range: U+0102-0103, U+0110-0111, U+0128-0129, U+0168-0169, U+01A0-01A1, U+01AF-01B0, U+0300-0301, U+0303-0304, U+0308-0309, U+0323, U+0329, U+1EA0-1EF9, U+20AB;\n}\n/* latin-ext */\n@font-face {\n  font-family: 'Space Grotesk';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"a7937b48-18c0-4e61-8fdd-8855e8f41cd6\") format('woff2');\n  unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;\n}\n/* latin */\n@font-face {\n  font-family: 'Space Grotesk';\n  font-style: normal;\n  font-weight: 700;\n  font-display: swap;\n  src: url(\"fc8bbabe-2914-4b64-9205-aae6e199c914\") format('woff2');\n  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;\n}\n\n\n:root {\n  --font-display: 'Space Grotesk', system-ui, sans-serif;\n  --font-body: 'Public Sans', system-ui, sans-serif;\n  --font-mono: 'SF Mono', 'Cascadia Mono', ui-monospace, monospace;\n\n  --r-sm: 8px;\n  --r-md: 12px;\n  --r-lg: 16px;\n  --r-xl: 22px;\n  --r-pill: 999px;\n\n  --tap: 48px; /* minimum tap target */\n}\n\n[data-theme=\"day\"] {\n  /* Brand */\n  --c-accent: #B3541E;\n  --c-accent-hover: #913F11;\n  --c-success: #6D7E4E;\n  --c-success-dark: #556640;\n  --c-info: #1a6fa6;\n  --c-danger: #C62828;\n  --c-warn: #FFB693;\n  --c-shared: #7a3d99;\n\n  /* Surfaces */\n  --c-bg: #F4FAFF;\n  --c-surface: #FFFFFF;\n  --c-surface-muted: #E8EDF2;\n  --c-surface-raised: #FFFFFF;\n  --c-nav-card: #FFFFFF;\n\n  /* Text */\n  --c-text: #131313;\n  --c-text-muted: #4A5058;\n  --c-text-inverse: #FFFFFF;\n\n  /* Borders */\n  --c-border: rgba(19,19,19,0.12);\n  --c-border-strong: rgba(19,19,19,0.25);\n\n  /* State backgrounds */\n  --c-error-bg: #FDECEA;\n  --c-error-text: #922018;\n  --c-warn-bg: #FFF3E0;\n  --c-warn-text: #8C5A00;\n  --c-danger-tint: rgba(198,40,40,0.10);\n  --c-accent-tint: rgba(179,84,30,0.10);\n  --c-info-tint: rgba(44,124,181,0.10);\n\n  --c-overlay: rgba(19,19,19,0.50);\n\n  /* Tab bar */\n  --c-tabbar-bg: #FFFFFF;\n  --c-tab-active: #B3541E;\n  --c-tab-inactive: #555D68;\n  --c-tab-centre-bg: #B3541E;\n  --c-tab-centre-icon: #FFFFFF;\n\n  /* Semantic categories */\n  --c-cat-emergency: #C62828;\n  --c-cat-water: #6D7E4E;\n  --c-cat-solar: #D4920A;\n  --c-cat-emergency-tint: rgba(198,40,40,0.12);\n  --c-cat-water-tint: rgba(109,126,78,0.12);\n  --c-cat-solar-tint: rgba(212,146,10,0.10);\n\n  /* Severity */\n  --c-sev-major: #C62828;\n  --c-sev-moderate: #E65100;\n  --c-sev-minor: #FFB693;\n\n  /* CTA gradient (signature, mostly used at night but kept for parity) */\n  --grad-cta: linear-gradient(135deg, #B3541E 0%, #913F11 100%);\n  --grad-cta-hover: linear-gradient(135deg, #913F11 0%, #6E2F09 100%);\n\n  /* Map (stylized faux-terrain) */\n  --map-bg: linear-gradient(180deg, #E8DFD0 0%, #DCC9A8 60%, #C9A876 100%);\n  --map-ridge: rgba(122, 84, 43, 0.18);\n  --map-route: #B3541E;\n  --map-route-cased: rgba(255,255,255,0.9);\n\n  /* Shadows */\n  --sh-card: 0 1px 2px rgba(19,19,19,0.06), 0 4px 12px rgba(19,19,19,0.08);\n  --sh-raised: 0 4px 12px rgba(19,19,19,0.10), 0 16px 32px rgba(19,19,19,0.10);\n  --sh-floating: 0 2px 8px rgba(19,19,19,0.08), 0 12px 28px rgba(19,19,19,0.14);\n\n  --status-bar-style: dark;\n}\n\n[data-theme=\"tactical-night\"] {\n  --c-accent: #D4764A;\n  --c-accent-hover: #B3541E;\n  --c-success: #8FA86A;\n  --c-success-dark: #6B8050;\n  --c-info: #4DB8F0;\n  --c-danger: #EF5350;\n  --c-warn: #FFB693;\n  --c-shared: #B087DB;\n\n  --c-bg: #131313;\n  --c-surface: rgba(26,28,32,0.96);\n  --c-surface-muted: rgba(38,40,46,0.94);\n  --c-surface-raised: rgba(48,50,56,0.97);\n  --c-nav-card: rgba(26,28,32,0.96);\n\n  --c-text: #F0ECE6;\n  --c-text-muted: #B0A89F;\n  --c-text-inverse: #131313;\n\n  --c-border: rgba(255,255,255,0.08);\n  --c-border-strong: rgba(255,255,255,0.16);\n\n  --c-error-bg: rgba(198,40,40,0.15);\n  --c-error-text: #FFAB91;\n  --c-warn-bg: rgba(255,182,147,0.12);\n  --c-warn-text: #FFB693;\n  --c-danger-tint: rgba(239,83,80,0.14);\n  --c-accent-tint: rgba(212,118,74,0.12);\n  --c-info-tint: rgba(77,184,240,0.12);\n\n  --c-overlay: rgba(0,0,0,0.65);\n\n  --c-tabbar-bg: rgba(18,18,22,0.97);\n  --c-tab-active: #D4764A;\n  --c-tab-inactive: #B0A89F;\n  --c-tab-centre-bg: #A0522D;\n  --c-tab-centre-icon: #FFFFFF;\n\n  --c-cat-emergency: #EF5350;\n  --c-cat-water: #8FA86A;\n  --c-cat-solar: #F0B429;\n  --c-cat-emergency-tint: rgba(239,83,80,0.14);\n  --c-cat-water-tint: rgba(143,168,106,0.14);\n  --c-cat-solar-tint: rgba(240,180,41,0.14);\n\n  --c-sev-major: #EF5350;\n  --c-sev-moderate: #FF8A65;\n  --c-sev-minor: #FFB693;\n\n  --grad-cta: linear-gradient(135deg, #FFB693 0%, #B3541E 100%);\n  --grad-cta-hover: linear-gradient(135deg, #D4764A 0%, #933D04 100%);\n\n  --map-bg: linear-gradient(180deg, #1a1612 0%, #221c14 60%, #2b2218 100%);\n  --map-ridge: rgba(255, 180, 100, 0.10);\n  --map-route: #D4764A;\n  --map-route-cased: rgba(0,0,0,0.6);\n\n  --sh-card: 0 1px 0 rgba(255,255,255,0.04), 0 8px 24px rgba(0,0,0,0.5);\n  --sh-raised: 0 8px 24px rgba(0,0,0,0.55), 0 24px 48px rgba(0,0,0,0.5);\n  --sh-floating: 0 4px 12px rgba(0,0,0,0.45), 0 20px 40px rgba(0,0,0,0.55);\n\n  --status-bar-style: light;\n}\n\n/* Base reset within the device screen */\n.roam-app, .roam-app * { box-sizing: border-box; }\n.roam-app {\n  width: 100%;\n  height: 100%;\n  background: var(--c-bg);\n  color: var(--c-text);\n  font-family: var(--font-body);\n  font-size: 15px;\n  line-height: 1.4;\n  position: relative;\n  overflow: hidden;\n}\n.roam-app button {\n  font-family: inherit;\n  font-size: inherit;\n  color: inherit;\n  background: none;\n  border: 0;\n  padding: 0;\n  cursor: pointer;\n}\n\n/* Typography helpers */\n.t-display { font-family: var(--font-display); letter-spacing: -0.01em; }\n.t-mono { font-family: var(--font-mono); }\n.t-muted { color: var(--c-text-muted); }\n.t-num { font-variant-numeric: tabular-nums; }\n\n/* Scrollbar hide for in-app scrollers */\n.scroll-y { overflow-y: auto; overflow-x: hidden; scrollbar-width: none; }\n.scroll-y::-webkit-scrollbar { display: none; }\n\n/* Page-area below status bar (62) and above tab bar (84 incl home indicator) */\n.page {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  flex-direction: column;\n}\n\n/* Animations */\n@keyframes pulse-soft { 0%,100% { opacity: 1 } 50% { opacity: 0.55 } }\n@keyframes sweep { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }\n@keyframes ping-ring {\n  0% { transform: scale(0.6); opacity: 0.9; }\n  100% { transform: scale(2.2); opacity: 0; }\n}\n@keyframes slide-up { from { transform: translateY(16px); opacity: 0 } to { transform: none; opacity: 1 } }\n@keyframes slide-in-right { from { transform: translateX(100%); } to { transform: translateX(0); } }\n@keyframes fade-in { from { opacity: 0 } to { opacity: 1 } }\n@keyframes cursor { 0%,49% { opacity: 1 } 50%,100% { opacity: 0 } }\n@keyframes dash { to { stroke-dashoffset: -24; } }\n</style>\n  <style>\n    html, body, #root { height: 100%; margin: 0; padding: 0; background: #0a0806; }\n    body { font-family: 'Public Sans', system-ui, sans-serif; }\n  </style>\n</head>\n<body>\n  <div id=\"root\"></div>\n\n  \n\n  <script src=\"7c94a6cc-f31a-45c3-84fb-521ddcf14e55\" integrity=\"sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L\" crossorigin=\"anonymous\"></script>\n  <script src=\"1d5cea7d-9edb-41be-a933-0d1db2852b39\" integrity=\"sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm\" crossorigin=\"anonymous\"></script>\n  <script src=\"5fab9db4-6b84-4d98-86ad-aaddce939c17\" integrity=\"sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y\" crossorigin=\"anonymous\"></script>\n\n  <script type=\"text/babel\" src=\"1f24c0ae-e822-484d-9247-ff91c9dd127d\"></script>\n  <script type=\"text/babel\" src=\"48c5af9e-5d90-4f55-80d9-bca22b3d5b09\"></script>\n  <script type=\"text/babel\" src=\"0c4805e6-a538-4d89-bd27-dd3f95b286e9\"></script>\n  <script type=\"text/babel\" src=\"eb82b6c0-b226-4e0c-bfcb-fab7e3c132da\"></script>\n  <script type=\"text/babel\" src=\"140e42e1-541c-49fe-b9f6-c5be39350f14\"></script>\n  <script type=\"text/babel\" src=\"672e5041-df9c-4f97-bfa2-9048c10e940e\"></script>\n  <script type=\"text/babel\" src=\"3e507596-cfa6-43bd-923c-7965cc787012\"></script>\n  <script type=\"text/babel\" src=\"598479fc-d1c8-43d4-b1c0-53233de03b61\"></script>\n\n\n</body></html>"