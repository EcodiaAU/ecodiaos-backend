{
  "mailer_subjects_recovery": "Reset your Chambers password",
  "mailer_subjects_confirmation": "Confirm your Chambers account",
  "mailer_subjects_invite": "You've been invited to Chambers",
  "mailer_subjects_magic_link": "Your Chambers sign-in link",
  "mailer_subjects_email_change": "Confirm your new email for Chambers",
  "mailer_templates_recovery_content": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width\"></head><body style=\"margin:0;padding:0;background:#f7f8fa;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#282828;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f7f8fa;padding:32px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;padding:32px;box-shadow:0 1px 2px rgba(15,23,42,0.04),0 4px 12px rgba(15,23,42,0.06);\"><tr><td style=\"padding-bottom:8px;\"><div style=\"font-size:22px;font-weight:700;color:#3d8f99;\">Chambers</div></td></tr><tr><td><h1 style=\"margin:8px 0 16px;font-size:22px;line-height:1.25;color:#282828;\">Reset your password</h1><p style=\"margin:0 0 20px;font-size:15px;line-height:1.55;color:#4b5563;\">Someone (hopefully you) asked to reset the password for the Chambers account at <strong>{{ .Email }}</strong>. Tap the button below within the next hour to choose a new password. If you didn't ask for this, you can ignore this email and your password stays the same.</p><p style=\"margin:0 0 24px;text-align:center;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#3d8f99;color:#ffffff;text-decoration:none;padding:14px 28px;border-radius:12px;font-weight:600;font-size:15px;\">Reset password</a></p><p style=\"margin:0 0 12px;font-size:13px;line-height:1.5;color:#6b7280;\">Button not working? Copy and paste this link into your browser:</p><p style=\"margin:0 0 20px;font-size:12px;line-height:1.5;word-break:break-all;color:#3d8f99;\"><a href=\"{{ .ConfirmationURL }}\" style=\"color:#3d8f99;text-decoration:underline;\">{{ .ConfirmationURL }}</a></p><hr style=\"border:none;border-top:1px solid #e5e7eb;margin:24px 0;\"><p style=\"margin:0;font-size:12px;line-height:1.5;color:#9ca3af;\">Chambers, the chamber of commerce platform for modern business communities. Sent from chambers@ecodia.au.</p></td></tr></table></td></tr></table></body></html>",
  "mailer_templates_confirmation_content": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width\"></head><body style=\"margin:0;padding:0;background:#f7f8fa;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#282828;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f7f8fa;padding:32px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;padding:32px;box-shadow:0 1px 2px rgba(15,23,42,0.04),0 4px 12px rgba(15,23,42,0.06);\"><tr><td style=\"padding-bottom:8px;\"><div style=\"font-size:22px;font-weight:700;color:#3d8f99;\">Chambers</div></td></tr><tr><td><h1 style=\"margin:8px 0 16px;font-size:22px;line-height:1.25;color:#282828;\">Confirm your email</h1><p style=\"margin:0 0 20px;font-size:15px;line-height:1.55;color:#4b5563;\">Welcome to Chambers. Tap the button below to confirm <strong>{{ .Email }}</strong> and finish setting up your account.</p><p style=\"margin:0 0 24px;text-align:center;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#3d8f99;color:#ffffff;text-decoration:none;padding:14px 28px;border-radius:12px;font-weight:600;font-size:15px;\">Confirm email</a></p><p style=\"margin:0 0 12px;font-size:13px;line-height:1.5;color:#6b7280;\">Button not working? Copy and paste this link:</p><p style=\"margin:0 0 20px;font-size:12px;line-height:1.5;word-break:break-all;color:#3d8f99;\"><a href=\"{{ .ConfirmationURL }}\" style=\"color:#3d8f99;text-decoration:underline;\">{{ .ConfirmationURL }}</a></p><hr style=\"border:none;border-top:1px solid #e5e7eb;margin:24px 0;\"><p style=\"margin:0;font-size:12px;line-height:1.5;color:#9ca3af;\">Chambers, the chamber of commerce platform for modern business communities. Sent from chambers@ecodia.au.</p></td></tr></table></td></tr></table></body></html>",
  "mailer_templates_magic_link_content": "<!doctype html><html><head><meta charset=\"utf-8\"></head><body style=\"margin:0;padding:0;background:#f7f8fa;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#282828;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f7f8fa;padding:32px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;padding:32px;box-shadow:0 1px 2px rgba(15,23,42,0.04),0 4px 12px rgba(15,23,42,0.06);\"><tr><td><div style=\"font-size:22px;font-weight:700;color:#3d8f99;margin-bottom:8px;\">Chambers</div><h1 style=\"margin:8px 0 16px;font-size:22px;color:#282828;\">Sign in to Chambers</h1><p style=\"margin:0 0 20px;font-size:15px;line-height:1.55;color:#4b5563;\">Tap the button below to sign in as <strong>{{ .Email }}</strong>. This link is single-use and expires in one hour.</p><p style=\"margin:0 0 24px;text-align:center;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#3d8f99;color:#ffffff;text-decoration:none;padding:14px 28px;border-radius:12px;font-weight:600;font-size:15px;\">Sign in</a></p><hr style=\"border:none;border-top:1px solid #e5e7eb;margin:24px 0;\"><p style=\"margin:0;font-size:12px;color:#9ca3af;\">If you didn't request this, ignore this email. Sent from chambers@ecodia.au.</p></td></tr></table></td></tr></table></body></html>",
  "mailer_templates_invite_content": "<!doctype html><html><head><meta charset=\"utf-8\"></head><body style=\"margin:0;padding:0;background:#f7f8fa;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#282828;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f7f8fa;padding:32px 12px;\"><tr><td align=\"center\"><table role=\"presentation\" width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:560px;background:#ffffff;border-radius:16px;padding:32px;box-shadow:0 1px 2px rgba(15,23,42,0.04),0 4px 12px rgba(15,23,42,0.06);\"><tr><td><div style=\"font-size:22px;font-weight:700;color:#3d8f99;margin-bottom:8px;\">Chambers</div><h1 style=\"margin:8px 0 16px;font-size:22px;color:#282828;\">You've been invited</h1><p style=\"margin:0 0 20px;font-size:15px;line-height:1.55;color:#4b5563;\">You've been invited to join a Chambers community on <strong>{{ .Email }}</strong>. Tap below to accept and set up your account.</p><p style=\"margin:0 0 24px;text-align:center;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#3d8f99;color:#ffffff;text-decoration:none;padding:14px 28px;border-radius:12px;font-weight:600;font-size:15px;\">Accept invitation</a></p><hr style=\"border:none;border-top:1px solid #e5e7eb;margin:24px 0;\"><p style=\"margin:0;font-size:12px;color:#9ca3af;\">Sent from chambers@ecodia.au.</p></td></tr></table></td></tr></table></body></html>",
  "mailer_templates_email_change_content": "<!doctype html><html><head><meta charset=\"utf-8\"></head><body style=\"margin:0;padding:0;background:#f7f8fa;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#282828;\"><table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f7f8fa;padding:32px 12px;\"><tr><td><div style=\"font-size:22px;font-weight:700;color:#3d8f99;margin-bottom:8px;\">Chambers</div><h1 style=\"margin:8px 0 16px;font-size:22px;color:#282828;\">Confirm your new email</h1><p style=\"margin:0 0 20px;font-size:15px;line-height:1.55;color:#4b5563;\">You requested to change your Chambers account email to <strong>{{ .NewEmail }}</strong>. Tap below to confirm. If you didn't request this, you can ignore this email.</p><p style=\"margin:0 0 24px;text-align:center;\"><a href=\"{{ .ConfirmationURL }}\" style=\"display:inline-block;background:#3d8f99;color:#ffffff;text-decoration:none;padding:14px 28px;border-radius:12px;font-weight:600;font-size:15px;\">Confirm email change</a></p><hr style=\"border:none;border-top:1px solid #e5e7eb;margin:24px 0;\"><p style=\"margin:0;font-size:12px;color:#9ca3af;\">Sent from chambers@ecodia.au.</p></td></tr></table></body></html>"
}
