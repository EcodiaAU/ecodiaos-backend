{
  "tool": "gui.sequence",
  "params": {
    "actions": [
      { "tool": "cdp.attach", "params": {} },
      { "tool": "cdp.navigate", "params": { "url": "https://vercel.com/ecodia/~/deployments", "waitUntil": "networkidle2", "timeout": 25000 } },
      { "tool": "cdp.wait", "params": { "selector": "main", "timeout": 8000 } },
      { "tool": "cdp.runJs", "params": { "js": "(function(){var rows=[];document.querySelectorAll('a[href*=\\\"/ecodia/\\\"][href*=\\\"/deployments/\\\"]').forEach(function(a){var u=a.getAttribute('href')||'';if(u.indexOf('/deployments/')<0)return;var txt=(a.textContent||'').trim().replace(/\\s+/g,' ').slice(0,200);rows.push({href:u,text:txt})});return {count:rows.length, rows:rows.slice(0,20)}})()" } },
      { "tool": "cdp.pageScreenshot", "params": { "fullPage": false } }
    ],
    "stopOnError": true,
    "finalScreenshot": true,
    "includeStepResults": true
  }
}
